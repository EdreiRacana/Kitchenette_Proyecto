# Local development variables — copy this file to ".env"
# In production (Render) these are configured as service environment variables.

# Secret used to sign JWT tokens — use a long random string
SECRET_KEY=changeme-use-a-long-random-string

# Optional full database URL. If empty, the app uses local SQLite.
# Postgres example: postgresql://user:password@host:5432/sthenova
# DATABASE_URL=
